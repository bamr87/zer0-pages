# Sample environment variables for zer0-pages
# Copy this file to .env and fill in your values

# Django Settings
DJANGO_SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=zer0_pages
DB_USER=zer0_pages
DB_PASSWORD=zer0_pages_dev
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0

# AI Providers (add your API keys)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEFAULT_AI_PROVIDER=openai

# GitHub Integration
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Analytics
PRIVACY_ANALYTICS_ENABLED=True
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Jekyll
JEKYLL_SOURCE_DIR=./frontend/public
JEKYLL_BUILD_DIR=./frontend/public/_site
